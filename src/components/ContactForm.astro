---
/**
 * Contact form component with Name, Email, Nachricht fields.
 * Styling is controlled by the parent via CSS variables and class props.
 */
interface Props {
  theme?: 'light' | 'dark' | 'warm' | 'cool';
  labels?: {
    name: string;
    namePlaceholder: string;
    email: string;
    emailPlaceholder: string;
    message: string;
    messagePlaceholder: string;
    submit: string;
    sending: string;
    success: string;
    error: string;
  };
}
const {
  theme = 'light',
  labels = {
    name: "Name",
    namePlaceholder: "Ihr Name",
    email: "E-Mail",
    emailPlaceholder: "ihre@email.de",
    message: "Nachricht",
    messagePlaceholder: "Ihre Nachricht...",
    submit: "Nachricht senden",
    sending: "Nachricht wird gesendet...",
    success: "Vielen Dank. Ihre Nachricht wurde erfolgreich versendet.",
    error: "Ihre Nachricht konnte gerade nicht gesendet werden.",
  },
} = Astro.props;

const themes = {
  light: {
    input: 'border-gray-200 bg-white text-gray-900 placeholder:text-gray-400 focus:border-brand focus:ring-brand/10',
    label: 'text-gray-600',
    button: 'bg-panel text-white hover:bg-brand',
  },
  dark: {
    input: 'border-white/10 bg-white/5 text-white placeholder:text-gray-500 focus:border-brand focus:ring-brand/10',
    label: 'text-gray-400',
    button: 'bg-brand text-white hover:bg-brand-deep',
  },
  warm: {
    input: 'border-warm-line bg-warm-field text-copy placeholder:text-warm-soft focus:border-brand focus:ring-brand/10',
    label: 'text-soft',
    button: 'bg-brand text-warm-field hover:bg-brand-deep',
  },
  cool: {
    input: 'border-cool-line bg-cool-field text-panel placeholder:text-cool-soft focus:border-brand focus:ring-brand/10',
    label: 'text-cool-muted',
    button: 'bg-brand text-white hover:bg-brand-deep',
  },
};

const t = themes[theme];
---

<form class="w-full space-y-6" action="/api/contact" method="POST" data-contact-form>
  <div>
    <label for="name" class={`block font-heading text-xs tracking-widest uppercase mb-3 ${t.label}`}>{labels.name}</label>
    <input 
      type="text" 
      id="name" 
      name="name" 
      required 
      placeholder={labels.namePlaceholder}
      class={`w-full px-5 py-4 border rounded-sm font-body text-base transition-all duration-300 outline-none focus:ring-4 ${t.input}`}
    />
  </div>
  <div>
    <label for="email" class={`block font-heading text-xs tracking-widest uppercase mb-3 ${t.label}`}>{labels.email}</label>
    <input 
      type="email" 
      id="email" 
      name="email" 
      required 
      placeholder={labels.emailPlaceholder}
      class={`w-full px-5 py-4 border rounded-sm font-body text-base transition-all duration-300 outline-none focus:ring-4 ${t.input}`}
    />
  </div>
  <div>
    <label for="nachricht" class={`block font-heading text-xs tracking-widest uppercase mb-3 ${t.label}`}>{labels.message}</label>
    <textarea 
      id="nachricht" 
      name="nachricht" 
      rows="5" 
      required 
      placeholder={labels.messagePlaceholder}
      class={`w-full px-5 py-4 border rounded-sm font-body text-base transition-all duration-300 outline-none focus:ring-4 resize-y ${t.input}`}
    ></textarea>
  </div>
  <div class="hidden" aria-hidden="true">
    <label for="website">Website</label>
    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
  </div>
  <p class={`hidden text-sm font-light ${t.label}`} data-contact-status role="status" aria-live="polite"></p>
  <button 
    type="submit" 
    data-contact-submit
    class={`w-full font-heading tracking-[0.2em] text-sm uppercase px-8 py-5 rounded-sm transition-all duration-300 cursor-pointer ${t.button}`}
  >
    {labels.submit}
  </button>
</form>

<script define:vars={{ contactFormLabels: labels }}>
  function initContactForms() {
    document.querySelectorAll("[data-contact-form]").forEach((form) => {
      if (!(form instanceof HTMLFormElement) || form.dataset.enhanced === "true") {
        return;
      }

      form.dataset.enhanced = "true";
      const submitButton = form.querySelector("[data-contact-submit]");
      const status = form.querySelector("[data-contact-status]");

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (!(submitButton instanceof HTMLButtonElement) || !(status instanceof HTMLElement)) {
          form.submit();
          return;
        }

        submitButton.disabled = true;
        status.classList.remove("hidden", "text-red-700", "text-green-700");
        status.textContent = contactFormLabels.sending;

        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
            headers: {
              Accept: "application/json",
            },
          });

          const payload = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(
              typeof payload?.error === "string"
                ? payload.error
                : contactFormLabels.error,
            );
          }

          form.reset();
          status.classList.add("text-green-700");
          status.textContent = contactFormLabels.success;
        } catch (error) {
          status.classList.add("text-red-700");
          status.textContent =
            error instanceof Error
              ? error.message
              : contactFormLabels.error;
        } finally {
          submitButton.disabled = false;
        }
      });
    });
  }

  initContactForms();
  document.addEventListener("astro:page-load", initContactForms);
</script>
