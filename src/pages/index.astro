---
import Layout from '../layouts/Layout.astro';
import Lightbox from '../components/Lightbox.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteData } from '../data/content';

const nav = [
  { href: '#about', label: 'Über mich' },
  { href: '#leistungen', label: 'Leistungen' },
  { href: '#instrumente', label: 'Instrumente' },
  { href: '#kontakt', label: 'Kontakt' }
];

const allInstruments = [
  ...siteData.instrumente.alemannische.images,
  ...siteData.instrumente.italienische.images,
];
const allOriginals = [
  ...siteData.instrumente.alemannische.originals,
  ...siteData.instrumente.italienische.originals,
];

const allImpressions = [
  ...siteData.impressionen.veranstaltungen.map(v => ({ ...v, category: 'Veranstaltung' })),
  ...siteData.impressionen.kunden.map(k => ({ ...k, category: 'Kunde' })),
  ...siteData.impressionen.presse.map(p => ({ ...p, category: 'Presse' })),
];
---

<Layout title="Dorothea Urbantat | Geigenbaumeisterin">
  <div class="bg-[#F9F6F1] min-h-screen font-body text-[#1a1a1a] selection:bg-[#4a6b8a] selection:text-white">
    
    {/* === NAV === */}
    <nav class="fixed top-0 left-0 w-full z-50 bg-[#F9F6F1]/90 backdrop-blur-lg border-b border-[#e0d6c8] ">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between">
        <a href="#" class="font-heading text-sm sm:text-lg tracking-[0.2em] sm:tracking-[0.25em] text-[#1a1a1a]">DOROTHEA URBANTAT</a>
        {/* Desktop nav */}
        <div class="hidden md:flex gap-10 font-heading text-xs tracking-[0.2em] text-[#6b6256] uppercase">
          {nav.map(l => (
            <a href={l.href} class="hover:text-[#4a6b8a] transition-colors duration-300">{l.label}</a>
          ))}
        </div>
        {/* Mobile hamburger */}
        <button id="mobile-menu-btn" class="md:hidden flex flex-col gap-[5px] p-2 -mr-2 cursor-pointer" aria-label="Menu">
          <span class="hamburger-line block w-5 h-[2px] bg-[#1a1a1a] transition-all duration-300 origin-center"></span>
          <span class="hamburger-line block w-5 h-[2px] bg-[#1a1a1a] transition-all duration-300"></span>
          <span class="hamburger-line block w-5 h-[2px] bg-[#1a1a1a] transition-all duration-300 origin-center"></span>
        </button>
      </div>
    </nav>
    {/* Mobile menu overlay — outside nav to avoid backdrop-filter containing block issues */}
    <div id="mobile-menu" class="md:hidden fixed top-16 left-0 right-0 bottom-0 bg-[#F9F6F1] border-t border-[#e0d6c8] flex flex-col items-center justify-center gap-6 py-8 opacity-0 pointer-events-none transition-opacity duration-300 z-50">
      {nav.map((l, i) => (
        <a href={l.href} class="mobile-nav-link font-heading text-lg tracking-[0.2em] text-[#1a1a1a] uppercase hover:text-[#4a6b8a] transition-colors px-6 py-3" style={`transition-delay: ${i * 50}ms`}>{l.label}</a>
      ))}
    </div>

    {/* === HERO === */}
    <section class="relative min-h-[100svh] flex items-center pt-16 sm:pt-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center py-12 lg:py-0">
          {/* Left side - Text content */}
          <div class="text-center lg:text-left reveal order-2 lg:order-1 overflow-hidden">
            <h1 class="font-heading text-3xl min-[400px]:text-4xl sm:text-5xl lg:text-6xl text-[#4a6b8a] tracking-[0.1em] uppercase mb-4 sm:mb-6">
              Geigenbaumeisterin
            </h1>
            <p class="font-heading text-5xl min-[400px]:text-6xl sm:text-7xl lg:text-8xl text-[#27313E] leading-[0.95] mb-8 sm:mb-10">
              DOROTHEA<br/>URBANTAT
            </p>
            <a href={`mailto:${siteData.impressum.kontakt.email}`} class="inline-block bg-[#4a6b8a] text-white font-heading text-sm sm:text-base tracking-[0.1em] px-6 sm:px-8 py-3 sm:py-4 mb-6 hover:bg-[#3a5a79] transition-colors duration-300 reveal" style="transition-delay:100ms">
              {siteData.impressum.kontakt.email}
            </a>
            <div class="flex items-center justify-center lg:justify-start gap-3 text-[#27313E] font-heading text-lg sm:text-xl tracking-wider reveal" style="transition-delay:150ms">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <a href={`tel:${siteData.impressum.kontakt.telefon.replace(/\s/g, '')}`} class="hover:text-[#4a6b8a] transition-colors">{siteData.impressum.kontakt.telefon}</a>
            </div>
          </div>
          {/* Right side - Violin image */}
          <div class="relative flex justify-center lg:justify-end reveal order-1 lg:order-2" style="transition-delay:200ms">
            <div class="relative">
              <img src={siteData.instrumente.alemannische.originals[0]} alt="Violine" class="h-[40vh] sm:h-[50vh] lg:h-[70vh] w-auto object-contain shadow-2xl" loading="eager" />
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* === ABOUT === */}
    <section id="about" class="py-16 sm:py-32 bg-[#F9F6F1]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-16 items-start">
          <div class="flex justify-center lg:sticky lg:top-32 reveal">
            <img src={siteData.about.portrait} alt="Dorothea Urbantat" class="h-[300px] sm:h-[500px] w-auto object-contain drop-shadow-xl" />
          </div>
          <div class="reveal" style="transition-delay:100ms">
            <div class="w-10 h-[3px] bg-[#4a6b8a] mb-6 sm:mb-8"></div>
            <h2 class="font-heading text-3xl sm:text-4xl text-[#27313E] mb-8 sm:mb-10">{siteData.about.title}</h2>
            <div class="space-y-4 sm:space-y-5 text-base sm:text-lg text-[#4a4238] font-light leading-relaxed">
              {siteData.about.paragraphs.map(p => <p>{p}</p>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* === IMPRESSIONEN === */}
    <section class="py-12 sm:py-20 bg-white overflow-hidden relative">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-8 sm:mb-12 reveal">
        <div class="flex items-center gap-3 sm:gap-4 mb-2">
          <div class="w-6 sm:w-8 h-[2px] bg-[#4a6b8a]"></div>
          <h3 class="font-heading text-xl sm:text-2xl text-[#27313E]">{siteData.impressionen.title}</h3>
        </div>
        <p class="text-[#8c8273] text-sm font-light">Veranstaltungen, Kunden & Presse</p>
      </div>

      {/* Fade edges */}
      <div class="absolute left-0 top-0 bottom-0 w-8 sm:w-24 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-8 sm:w-24 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

      <div class="impressions-track flex gap-4 sm:gap-6 px-4 sm:px-6 overflow-x-auto snap-x snap-mandatory hide-scrollbar pb-4">
        {allImpressions.map(item => (
          <div class="flex-none w-[260px] sm:w-[320px] snap-center bg-[#F9F6F1] rounded-lg p-4 sm:p-6 shadow-sm hover:shadow-md transition-shadow duration-300 border border-[#e0d6c8]/50">
            <span class="inline-block px-3 py-1 rounded-full text-[10px] font-heading tracking-[0.15em] uppercase bg-[#4a6b8a]/10 text-[#4a6b8a] mb-3 sm:mb-4">{item.category}</span>
            {item.url ? (
              <a href={item.url} target="_blank" rel="noopener noreferrer" class="block text-[#27313E] font-medium text-sm leading-relaxed hover:text-[#4a6b8a] transition-colors">
                {item.text}
                <span class="block mt-2 sm:mt-3 text-[#4a6b8a] font-heading text-xs tracking-wider uppercase">Mehr erfahren &rarr;</span>
              </a>
            ) : (
              <p class="text-[#27313E] font-medium text-sm leading-relaxed">{item.text}</p>
            )}
          </div>
        ))}
      </div>
    </section>

    {/* === LEISTUNGEN === */}
    <section id="leistungen" class="py-16 sm:py-32 bg-[#F9F6F1]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4 reveal">
          <div class="w-8 sm:w-10 h-[3px] bg-[#4a6b8a]"></div>
          <h2 class="font-heading text-3xl sm:text-4xl text-[#27313E]">Leistungen</h2>
        </div>
        <p class="text-[#8c8273] text-sm sm:text-base font-light mb-12 sm:mb-24 reveal">Vom Neubau bis zur Reparatur</p>
        <div class="space-y-16 sm:space-y-28">
          {siteData.leistungen.items.map((item, i) => {
            const isSmall = item.id === 'neubau' || item.id === 'leihinstrumente';
            return (
              <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 sm:gap-12 items-center reveal">
                <div class={`lg:col-span-3 ${i % 2 === 1 ? 'lg:order-2' : ''} order-2 lg:order-none`}>
                  <span class="font-heading text-[#4a6b8a] text-4xl sm:text-5xl opacity-25 block mb-2 sm:mb-3">0{i + 1}</span>
                  <h3 class="font-heading text-2xl sm:text-3xl mb-4 sm:mb-5 text-[#27313E]">{item.title}</h3>
                  <p class="text-[#4a4238] font-light leading-relaxed text-base sm:text-lg mb-4 sm:mb-6">{item.description}</p>
                  {item.preise && (
                    <ul class="space-y-3 font-heading text-sm tracking-wider text-[#6b6256]">
                      {item.preise.map(p => (
                        <li class="flex justify-between border-b border-[#e0d6c8] pb-2">
                          <span>{p.label}</span>
                          <span class="text-[#4a6b8a] font-semibold">{p.price}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
                <div class={`lg:col-span-2 ${i % 2 === 1 ? 'lg:order-1' : ''} order-1 lg:order-none flex justify-center`}>
                  <img
                    src={item.image}
                    alt={item.title}
                    class={`h-auto rounded-sm shadow-lg ${isSmall ? 'w-[140px] sm:w-[200px]' : 'w-[180px] sm:w-full sm:max-w-xs'}`}
                    loading="lazy"
                  />
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    {/* === INSTRUMENTE === */}
    <section id="instrumente" class="py-16 sm:py-32 bg-[#27313E] text-white overflow-hidden">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-10 sm:mb-16 reveal">
        <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
          <div class="w-8 sm:w-10 h-[3px] bg-[#4a6b8a]"></div>
          <h2 class="font-heading text-3xl sm:text-4xl">Meisterinstrumente</h2>
        </div>
        <p class="font-heading tracking-[0.2em] sm:tracking-[0.3em] text-[#8c9bab] uppercase text-[10px] sm:text-xs">Alemannische & Italienische Bauweise</p>
      </div>
      <div class="flex overflow-x-auto pb-10 sm:pb-16 px-4 sm:px-6 gap-8 sm:gap-16 snap-x snap-mandatory hide-scrollbar">
        {allInstruments.map((img, i) => (
          <div class="flex-none w-[200px] sm:w-[280px] h-[360px] sm:h-[520px] snap-center flex items-center justify-center relative group" data-lightbox-src={allOriginals[i]}>
            <div class="absolute inset-x-4 sm:inset-x-6 bottom-4 sm:bottom-6 h-10 sm:h-16 bg-white/10 blur-2xl rounded-full scale-50 group-hover:scale-100 transition-transform duration-1000"></div>
            <img src={img} alt={`Instrument ${i+1}`} class="h-[90%] w-auto object-contain relative z-10 group-hover:-translate-y-4 transition-transform duration-700 drop-shadow-[0_25px_50px_rgba(0,0,0,0.8)]" loading="lazy" />
          </div>
        ))}
      </div>
      <Lightbox theme="dark" />
    </section>

    {/* === KONTAKT === */}
    <section id="kontakt" class="py-16 sm:py-32 bg-white">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 reveal">
        <div class="flex items-center justify-center gap-3 sm:gap-4 mb-4">
          <div class="w-8 sm:w-10 h-[3px] bg-[#4a6b8a]"></div>
          <h2 class="font-heading text-3xl sm:text-4xl text-[#27313E]">{siteData.kontakt.title}</h2>
          <div class="w-8 sm:w-10 h-[3px] bg-[#4a6b8a]"></div>
        </div>
        <p class="text-[#6b6256] font-light text-base sm:text-lg text-center mb-8 sm:mb-12 max-w-xl mx-auto">{siteData.kontakt.intro}</p>
        <ContactForm theme="cool" />
        <p class="text-center text-sm text-[#8c8273] mt-8 sm:mt-10 italic">{siteData.kontakt.greeting}</p>
      </div>
    </section>

    <footer class="py-12 sm:py-16 bg-[#27313E]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col items-center gap-8 sm:gap-6 sm:flex-row sm:justify-between font-heading text-[10px] sm:text-[11px] tracking-[0.2em] text-[#8c9bab]">
        <div class="flex flex-col items-center sm:items-start gap-3">
          <p>&copy; {new Date().getFullYear()} Dorothea Urbantat.</p>
          <div class="flex gap-4">
            <a href="/impressum" class="hover:text-[#4a6b8a] transition-colors">Impressum</a>
            <a href="/datenschutz" class="hover:text-[#4a6b8a] transition-colors">Datenschutzerklärung</a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-8">
          <a href={`tel:${siteData.impressum.kontakt.telefon.replace(/\s/g, '')}`} class="hover:text-[#4a6b8a] transition-colors">{siteData.impressum.kontakt.telefon}</a>
          <a href={`mailto:${siteData.impressum.kontakt.email}`} class="hover:text-[#4a6b8a] transition-colors">{siteData.impressum.kontakt.email}</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  /* Hamburger animation */
  .menu-open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .menu-open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
</style>

<script>
  function initPage() {
    // Scroll reveal
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { if (entry.isIntersecting) entry.target.classList.add('active'); });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // Mobile menu
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    btn.addEventListener('click', () => {
      const isOpen = menu.classList.contains('opacity-100');
      if (isOpen) {
        menu.classList.remove('opacity-100');
        menu.classList.add('opacity-0', 'pointer-events-none');
        btn.classList.remove('menu-open');
        document.body.style.overflow = '';
      } else {
        menu.classList.remove('opacity-0', 'pointer-events-none');
        menu.classList.add('opacity-100');
        btn.classList.add('menu-open');
        document.body.style.overflow = 'hidden';
      }
    });

    // Close menu when clicking a link
    menu.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.remove('opacity-100');
        menu.classList.add('opacity-0', 'pointer-events-none');
        btn.classList.remove('menu-open');
        document.body.style.overflow = '';
      });
    });

    // Initial scroll for impressions track to snap the second item (index 1) to the center
    const track = document.querySelector('.impressions-track');
    if (track && track.children.length > 1) {
      setTimeout(() => {
        const secondItem = track.children[1] as HTMLElement;
        const offset = secondItem.offsetLeft - (track.clientWidth / 2) + (secondItem.offsetWidth / 2);
        track.scrollTo({ left: offset > 0 ? offset : 0, behavior: 'smooth' });
      }, 300); // Small delay to ensure layout is calculated
    }
  }

  document.addEventListener('DOMContentLoaded', initPage);
  document.addEventListener('astro:page-load', initPage);
</script>
