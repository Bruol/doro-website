---
import Layout from "../layouts/Layout.astro";
import Lightbox from "../components/Lightbox.astro";
import ContactForm from "../components/ContactForm.astro";
import { siteData } from "../data/content";

const nav = [
  { href: "#about", label: "Über mich" },
  { href: "#leistungen", label: "Leistungen" },
  { href: "#instrumente", label: "Instrumente" },
  { href: "#kontakt", label: "Kontakt" },
];

const allInstrumentItems = [
  ...siteData.instrumente.alemannische.images.map((image, index) => ({
    image,
    original: siteData.instrumente.alemannische.originals[index],
    scale: siteData.instrumente.alemannische.scales[index] ?? 1,
  })),
  ...siteData.instrumente.italienische.images.map((image, index) => ({
    image,
    original: siteData.instrumente.italienische.originals[index],
    scale: siteData.instrumente.italienische.scales[index] ?? 1,
  })),
];
---

<Layout title="Dorothea Urbantat | Geigenbaumeisterin">
  <div
    class="min-h-screen bg-surface font-body text-ink selection:bg-brand selection:text-white"
  >
    {/* === NAV === */}
    <nav
      class="fixed top-0 left-0 z-50 w-full border-b border-line bg-surface/90 backdrop-blur-lg"
    >
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between"
      >
        <a
          href="#"
          class="font-heading text-sm tracking-[0.2em] text-ink sm:text-lg sm:tracking-[0.25em]"
          >DOROTHEA URBANTAT</a
        >
        {/* Desktop nav */}
        <div
          class="hidden gap-10 font-heading text-xs uppercase tracking-[0.2em] text-muted md:flex"
        >
          {
            nav.map((l) => (
              <a
                href={l.href}
                class="transition-colors duration-300 hover:text-brand"
              >
                {l.label}
              </a>
            ))
          }
        </div>
        {/* Mobile hamburger */}
        <button
          id="mobile-menu-btn"
          class="-mr-2 flex cursor-pointer flex-col gap-[5px] p-2 md:hidden"
          aria-label="Menu"
        >
          <span
            class="hamburger-line block h-[2px] w-5 origin-center bg-ink transition-all duration-300"
          ></span>
          <span
            class="hamburger-line block h-[2px] w-5 bg-ink transition-all duration-300"
          ></span>
          <span
            class="hamburger-line block h-[2px] w-5 origin-center bg-ink transition-all duration-300"
          ></span>
        </button>
      </div>
    </nav>
    {
      /* Mobile menu overlay — outside nav to avoid backdrop-filter containing block issues */
    }
    <div
      id="mobile-menu"
      class="fixed top-16 right-0 bottom-0 left-0 z-50 flex flex-col items-center justify-center gap-6 border-t border-line bg-surface py-8 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
    >
      {
        nav.map((l, i) => (
          <a
            href={l.href}
            class="mobile-nav-link px-6 py-3 font-heading text-lg uppercase tracking-[0.2em] text-ink transition-colors hover:text-brand"
            style={`transition-delay: ${i * 50}ms`}
          >
            {l.label}
          </a>
        ))
      }
    </div>

    {/* === HERO === */}
    <section
      class="relative min-h-[100svh] flex items-center pt-16 sm:pt-20 bg-white"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 w-full">
        <div
          class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center py-12 lg:py-0"
        >
          {/* Left side - Text content */}
          <div
            class="text-center lg:text-left reveal order-2 lg:order-1 overflow-hidden"
          >
            <h1
              class="mb-4 font-heading text-3xl uppercase tracking-[0.1em] text-brand min-[400px]:text-4xl sm:mb-6 sm:text-5xl lg:text-6xl"
            >
              Geigenbau meisterin
            </h1>
            <a
              href={`mailto:${siteData.impressum.kontakt.email}`}
              class="reveal mb-6 inline-block bg-brand px-6 py-3 font-heading text-sm tracking-[0.1em] text-white transition-colors duration-300 hover:bg-brand-deep sm:px-8 sm:py-4 sm:text-base"
              style="transition-delay:100ms"
            >
              {siteData.impressum.kontakt.email}
            </a>
            <div
              class="reveal flex flex-col items-center justify-center gap-3 font-heading text-lg tracking-wider text-panel sm:text-xl lg:items-start lg:justify-start"
              style="transition-delay:150ms"
            >
              <div
                class="flex items-center justify-center gap-3 lg:justify-start"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"
                  ></path></svg
                >
                <a
                  href={`tel:${siteData.impressum.kontakt.telefon.replace(/\s/g, "")}`}
                  class="transition-colors hover:text-brand"
                  >{siteData.impressum.kontakt.telefon}</a
                >
              </div>
              <a
                href={siteData.impressum.kontakt.instagramUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 transition-colors hover:text-brand"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect x="3.5" y="3.5" width="17" height="17" rx="4"></rect>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="17.5" cy="6.5" r="1"></circle>
                </svg>
                <span>{siteData.impressum.kontakt.instagramHandle}</span>
              </a>
            </div>
          </div>
          {/* Right side - Violin image */}
          <div
            class="relative flex justify-center lg:justify-end reveal order-1 lg:order-2"
            style="transition-delay:200ms"
          >
            <div class="relative">
              <img
                src={"/assets/images/alemannische-01-no-bg.png"}
                alt="Violine"
                class="h-[40vh] sm:h-[50vh] lg:h-[70vh] w-auto bg-transparent object-contain lg:ml-12 xl:ml-16"
                loading="eager"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* === ABOUT === */}
    <section id="about" class="bg-surface py-16 sm:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div
          class="grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-16 items-start"
        >
          <div class="flex justify-center lg:sticky lg:top-32 reveal">
            <img
              src={siteData.about.portrait}
              alt="Dorothea Urbantat"
              class="h-[300px] sm:h-[500px] w-auto object-contain drop-shadow-xl"
            />
          </div>
          <div class="reveal" style="transition-delay:100ms">
            <div class="mb-6 h-[3px] w-10 bg-brand sm:mb-8"></div>
            <h2
              class="mb-8 font-heading text-3xl text-panel sm:mb-10 sm:text-4xl"
            >
              {siteData.about.title}
            </h2>
            <div
              class="space-y-4 text-base font-light leading-relaxed text-copy sm:space-y-5 sm:text-lg"
            >
              {siteData.about.paragraphs.map((p) => <p>{p}</p>)}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* === LEISTUNGEN === */}
    <section id="leistungen" class="bg-white py-16 sm:py-32">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="reveal mb-3 flex items-center gap-3 sm:mb-4 sm:gap-4">
          <div class="h-[3px] w-8 bg-brand sm:w-10"></div>
          <h2 class="font-heading text-3xl text-panel sm:text-4xl">
            Leistungen
          </h2>
        </div>
        <p
          class="reveal mb-12 text-sm font-light text-soft sm:mb-24 sm:text-base"
        >
          Vom Neubau bis zur Reparatur
        </p>
        <div class="space-y-16 sm:space-y-28">
          {
            siteData.leistungen.items.map((item, i) => {
              const isSmall =
                item.id === "neubau" || item.id === "leihinstrumente";
              return (
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 sm:gap-12 items-center reveal">
                  <div
                    class={`lg:col-span-3 ${i % 2 === 1 ? "lg:order-2" : ""} order-2 lg:order-none`}
                  >
                    <span class="mb-2 block font-heading text-4xl text-brand/25 sm:mb-3 sm:text-5xl">
                      0{i + 1}
                    </span>
                    <h3 class="mb-4 font-heading text-2xl text-panel sm:mb-5 sm:text-3xl">
                      {item.title}
                    </h3>
                    <p class="mb-4 text-base font-light leading-relaxed text-copy sm:mb-6 sm:text-lg">
                      {item.description}
                    </p>
                    {item.preise && (
                      <ul class="space-y-3 font-heading text-sm tracking-wider text-muted">
                        {item.preise.map((p) => (
                          <li class="flex justify-between border-b border-line pb-2">
                            <span>{p.label}</span>
                            <span class="font-semibold text-brand">
                              {p.price}
                            </span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                  <div
                    class={`lg:col-span-2 ${i % 2 === 1 ? "lg:order-1" : ""} order-1 lg:order-none flex justify-center`}
                  >
                    <img
                      src={item.image}
                      alt={item.title}
                      class={`h-auto rounded-sm bg-transparent  ${isSmall ? "w-[140px] sm:w-[200px]" : "w-[180px] sm:w-full sm:max-w-xs"}`}
                      loading="lazy"
                    />
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    {/* === INSTRUMENTE === */}
    <section
      id="instrumente"
      class="overflow-hidden bg-panel py-16 text-white sm:py-24"
    >
      <div>
        <div class="mb-10 sm:mb-16 reveal px-4 sm:px-6">
          <div class="max-w-7xl mx-auto">
          <div class="flex items-center gap-3 sm:gap-4 mb-3 sm:mb-4">
            <div class="h-[3px] w-8 bg-brand sm:w-10"></div>
            <h2 class="font-heading text-3xl sm:text-4xl">
              Meisterinstrumente
            </h2>
          </div>
          <p
            class="font-heading text-[10px] uppercase tracking-[0.2em] text-cool-soft sm:text-xs sm:tracking-[0.3em]"
          >
            Alemannische & Italienische Bauweise
          </p>
          </div>
        </div>
        <div class="flex overflow-x-auto overflow-y-hidden pb-10 sm:pb-16 gap-12 sm:gap-24 snap-x snap-mandatory hide-scrollbar">{allInstrumentItems.map((item, i) => (
          <div
            class="flex-none w-[200px] sm:w-[380px] h-[300px] sm:h-[700px] snap-center flex items-center justify-center relative group"
            data-lightbox-src={item.original}
          >
            <div class="absolute inset-x-10 bottom-5 h-6 rounded-full bg-black/20 blur-xl opacity-70 transition-all duration-500 group-hover:opacity-90"></div>
            <img
              src={item.image}
              alt={`Instrument ${i + 1}`}
              class="h-[90%] w-auto object-contain relative z-10 group-hover:-translate-y-4 transition-transform duration-700 drop-shadow-[0_10px_18px_rgba(0,0,0,0.28)]"
              style={`scale: ${item.scale};`}
              loading="lazy"
            />
          </div>
        ))}</div>
      </div>
      <Lightbox theme="dark" />
    </section>
    {/* === REFERENZ === */}
    <section class="bg-white py-16 sm:py-24">
      <div class="max-w-5xl mx-auto px-4 sm:px-6">
        <div
          role="link"
          tabindex="0"
          onclick={`window.open('${siteData.testimonial.websiteUrl}', '_blank', 'noopener,noreferrer')`}
          onkeydown={`if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); window.open('${siteData.testimonial.websiteUrl}', '_blank', 'noopener,noreferrer'); }`}
          class="reveal grid gap-8 rounded-[2rem] border border-line/70 bg-surface p-6 shadow-sm sm:grid-cols-[220px_minmax(0,1fr)] sm:items-center sm:gap-10 sm:p-10"
        >
          <div
            class="mx-auto w-full max-w-[220px] overflow-hidden rounded-[1.5rem] bg-white"
          >
            <img
              src={siteData.testimonial.image}
              alt={siteData.testimonial.name}
              class="aspect-square w-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="max-w-3xl">
            <span
              class="mb-4 inline-block rounded-full bg-brand/10 px-4 py-1 font-heading text-[10px] uppercase tracking-[0.2em] text-brand sm:mb-6"
            >
              {siteData.testimonial.eyebrow}
            </span>
            <h3 class="font-heading text-3xl text-panel sm:text-4xl">
              {siteData.testimonial.name}
            </h3>
            <div class="mt-3 flex items-center gap-2">
              <p class="text-base font-light text-muted sm:text-lg">
                {siteData.testimonial.role}
              </p>
              <div class="flex items-center text-panel">
                <a
                  href={siteData.testimonial.websiteUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  onclick="event.stopPropagation()"
                  aria-label={`${siteData.testimonial.name} Website`}
                  class="inline-flex h-9 w-9 items-center justify-center transition-colors hover:text-brand"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <circle cx="12" cy="12" r="9"></circle>
                    <path d="M3 12h18"></path>
                    <path d="M12 3a15 15 0 0 1 0 18"></path>
                    <path d="M12 3a15 15 0 0 0 0 18"></path>
                  </svg>
                </a>
                <a
                  href={siteData.testimonial.instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  onclick="event.stopPropagation()"
                  aria-label={`${siteData.testimonial.name} Instagram`}
                  class="inline-flex h-9 w-9 items-center justify-center transition-colors hover:text-brand"
                >
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="3.5" y="3.5" width="17" height="17" rx="4"></rect>
                    <circle cx="12" cy="12" r="4"></circle>
                    <circle cx="17.5" cy="6.5" r="1"></circle>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    {/* === KONTAKT === */}
    <section id="kontakt" class="bg-white py-16 sm:py-32">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 reveal">
        <div class="mb-4 flex items-center justify-center gap-3 sm:gap-4">
          <div class="h-[3px] w-8 bg-brand sm:w-10"></div>
          <h2 class="font-heading text-3xl text-panel sm:text-4xl">
            {siteData.kontakt.title}
          </h2>
          <div class="h-[3px] w-8 bg-brand sm:w-10"></div>
        </div>
        <p
          class="mx-auto mb-8 max-w-xl text-center text-base font-light text-muted sm:mb-12 sm:text-lg"
        >
          {siteData.kontakt.intro}
        </p>
        <ContactForm theme="cool" />
        <p class="mt-8 text-center text-sm italic text-soft sm:mt-10">
          {siteData.kontakt.greeting}
        </p>
      </div>
    </section>

    <footer class="bg-panel py-12 sm:py-16">
      <div
        class="max-w-7xl mx-auto flex flex-col items-center gap-8 px-4 font-heading text-[10px] tracking-[0.2em] text-cool-soft sm:flex-row sm:justify-between sm:gap-6 sm:px-6 sm:text-[11px]"
      >
        <div class="flex flex-col items-center sm:items-start gap-3">
          <p>&copy; {new Date().getFullYear()} Dorothea Urbantat.</p>
          <div class="flex gap-4">
            <a href="/impressum" class="transition-colors hover:text-brand"
              >Impressum</a
            >
            <a href="/datenschutz" class="transition-colors hover:text-brand"
              >Datenschutzerklärung</a
            >
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-8">
          <a
            href={`tel:${siteData.impressum.kontakt.telefon.replace(/\s/g, "")}`}
            class="transition-colors hover:text-brand"
            >{siteData.impressum.kontakt.telefon}</a
          >
          <a
            href={`mailto:${siteData.impressum.kontakt.email}`}
            class="transition-colors hover:text-brand"
            >{siteData.impressum.kontakt.email}</a
          >
        </div>
      </div>
    </footer>
  </div>
</Layout>

<script>
  function initPage() {
    // Scroll reveal
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) entry.target.classList.add("active");
        });
      },
      { threshold: 0.1 },
    );
    document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));

    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    if (btn && menu) {
      btn.addEventListener("click", () => {
        const isOpen = menu.classList.contains("opacity-100");
        if (isOpen) {
          menu.classList.remove("opacity-100");
          menu.classList.add("opacity-0", "pointer-events-none");
          btn.classList.remove("menu-open");
          document.body.style.overflow = "";
        } else {
          menu.classList.remove("opacity-0", "pointer-events-none");
          menu.classList.add("opacity-100");
          btn.classList.add("menu-open");
          document.body.style.overflow = "hidden";
        }
      });

      menu.querySelectorAll(".mobile-nav-link").forEach((link) => {
        link.addEventListener("click", () => {
          menu.classList.remove("opacity-100");
          menu.classList.add("opacity-0", "pointer-events-none");
          btn.classList.remove("menu-open");
          document.body.style.overflow = "";
        });
      });
    }
  }

  document.addEventListener("DOMContentLoaded", initPage);
  document.addEventListener("astro:page-load", initPage);
</script>
