---
import Layout from '../layouts/Layout.astro';
import { siteData } from '../data/content';

const impressum = siteData.impressum;
---

<Layout title="Impressum | Dorothea Urbantat">
  <div class="min-h-screen bg-surface font-body text-ink selection:bg-brand selection:text-white">

    {/* === NAV === */}
    <nav class="fixed top-0 left-0 z-50 w-full border-b border-line bg-surface/90 backdrop-blur-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 sm:h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-4 font-heading text-sm tracking-[0.2em] text-ink sm:text-lg sm:tracking-[0.25em]">
          <span class="text-brand">&larr;</span> DOROTHEA URBANTAT
        </a>
      </div>
    </nav>

    {/* === CONTENT === */}
    <main class="pt-32 pb-20 max-w-3xl mx-auto px-4 sm:px-6 min-h-[80svh]">
      <div class="mb-12">
        <div class="mb-4 flex items-center gap-3 sm:gap-4">
          <div class="h-[3px] w-8 bg-brand sm:w-10"></div>
          <h1 class="font-heading text-3xl text-panel sm:text-4xl">{impressum.title}</h1>
        </div>
        <p class="font-heading text-xs uppercase tracking-[0.2em] text-soft">Angaben gemäß § 5 TMG</p>
      </div>

      <div class="space-y-12 font-light leading-relaxed text-copy">
        
        <section>
          <h2 class="mb-4 font-heading text-lg text-panel">Kontaktadressen</h2>
          <div class="grid gap-8 sm:grid-cols-2">
            {impressum.angaben.map(ort => (
              <div>
                <p class="font-medium text-panel">{ort.name}</p>
                <p class="mb-2 text-sm text-soft">{ort.title}</p>
                <p class="whitespace-pre-line">{ort.address}</p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h2 class="mb-4 font-heading text-lg text-panel">Kontakt</h2>
          <p>Telefon: <a href={`tel:${impressum.kontakt.telefon.replace(/\s/g, '')}`} class="transition-colors hover:text-brand">{impressum.kontakt.telefon}</a></p>
          <p>E-Mail: <a href={`mailto:${impressum.kontakt.email}`} class="transition-colors hover:text-brand">{impressum.kontakt.email}</a></p>
        </section>

        <section>
          <h2 class="mb-4 font-heading text-lg text-panel">Berufsbezeichnung und berufsrechtliche Regelungen</h2>
          <p>Berufsbezeichnung: {impressum.berufsbezeichnung}</p>
          <p>Zuständige Kammer: {impressum.kammer}</p>
          <p>Verliehen durch: {impressum.verliehen_durch}</p>
        </section>
        
        <section>
          <h2 class="mb-4 font-heading text-lg text-panel">Verbraucherstreitbeilegung/Universalschlichtungsstelle</h2>
          <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>
        </section>

      </div>
    </main>

    <footer class="mt-auto border-t border-line/10 bg-panel py-12 sm:py-16">
      <div class="max-w-7xl mx-auto flex flex-col items-center px-4 text-center font-heading text-[10px] tracking-[0.2em] text-cool-soft sm:px-6 sm:text-[11px]">
        <p>&copy; {new Date().getFullYear()} Dorothea Urbantat. All Rights Reserved.</p>
      </div>
    </footer>
  </div>
</Layout>
